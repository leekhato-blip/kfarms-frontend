# Render web service env for shared staging
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=10000

# Render Postgres
KFARMS_DB_URL=jdbc:postgresql://db-host:5432/kfarms_db
KFARMS_DB_USERNAME=replace-me
KFARMS_DB_PASSWORD=replace-me

# Public app URLs
KFARMS_FRONTEND_BASE_URL=https://kfarms-app-staging.onrender.com
KFARMS_CORS_ALLOWED_ORIGINS=https://kfarms-app-staging.onrender.com

# Auth / cookies
KFARMS_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
KFARMS_COOKIE_SECURE=true
KFARMS_COOKIE_SAMESITE=None
KFARMS_COOKIE_DOMAIN=

# Staging-first defaults
SPRING_JPA_HIBERNATE_DDL_AUTO=update
KFARMS_AUTH_VERIFICATION_PREVIEW_ENABLED=true
KFARMS_SMS_ENABLED=false
KFARMS_SMS_PREVIEW_LOGGING_ENABLED=true
KFARMS_PAYSTACK_ENABLED=false

# Add these later when you want real delivery in staging
KFARMS_SMTP_HOST=
KFARMS_SMTP_PORT=587
KFARMS_SMTP_USERNAME=
KFARMS_SMTP_PASSWORD=
KFARMS_SMS_WEBHOOK_URL=
KFARMS_SMS_API_KEY=
