# Optional: set this when your frontend talks to a dedicated API origin.
# If omitted, the app uses http://localhost:8080/api on localhost
# and /api on deployed origins.
VITE_API_BASE_URL=https://api.example.com/api

# Optional platform auth overrides
VITE_PLATFORM_AUTH_LOGIN_URL=/api/auth/login
VITE_PLATFORM_LOGIN_IDENTIFIER_KEY=emailOrUsername
