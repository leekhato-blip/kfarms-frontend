POSTGRES_DB=kfarms_db
POSTGRES_USER=kfarms_user
POSTGRES_PASSWORD=replace-me

# Update this if your backend repo lives somewhere else on the deploy machine.
KFARMS_BACKEND_BUILD_CONTEXT=/home/lee/Documents/kfarms-backend

# Public app URL that users will open in the browser.
KFARMS_PUBLIC_URL=https://app.example.com
KFARMS_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Recommended this week: same-origin deployment through nginx on one public URL.
# Keep `Lax` and an empty cookie domain in that setup.
# Only switch to `SameSite=None` and a shared parent domain if frontend and backend
# will live on different subdomains later.
KFARMS_COOKIE_SECURE=true
KFARMS_COOKIE_SAMESITE=Lax
KFARMS_COOKIE_DOMAIN=
KFARMS_COOKIE_MAX_AGE_DAYS=7
KFARMS_CORS_ALLOWED_ORIGINS=https://app.example.com
KFARMS_CORS_ALLOWED_ORIGIN_PATTERNS=

# Production verification and reset delivery
# Set both preview flags to false in production so codes are never exposed in the UI or logs.
KFARMS_SMTP_HOST=smtp.gmail.com
KFARMS_SMTP_PORT=587
KFARMS_SMTP_USERNAME=
KFARMS_SMTP_PASSWORD=
KFARMS_SMS_ENABLED=true
KFARMS_SMS_WEBHOOK_URL=
KFARMS_SMS_API_KEY=
KFARMS_SMS_SENDER=KFarms
KFARMS_SMS_PREVIEW_LOGGING_ENABLED=false
KFARMS_AUTH_VERIFICATION_PREVIEW_ENABLED=false

# Optional integrations
KFARMS_PAYSTACK_ENABLED=false
KFARMS_PAYSTACK_SECRET_KEY=
KFARMS_PAYSTACK_PRO_MONTHLY_PLAN_CODE=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

FRONTEND_PORT=80
